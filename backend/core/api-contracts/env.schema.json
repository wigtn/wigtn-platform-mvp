{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wigtn-web-agency/env.schema.json",
  "title": "생성 프로젝트 환경변수 계약 (UNIFIED-PRD §2.7)",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "NEXT_PUBLIC_APP_ENV",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY",
    "APP_DATABASE_URL"
  ],
  "properties": {
    "NEXT_PUBLIC_APP_ENV": {
      "enum": ["local", "internal-preview", "staging", "production"]
    },
    "NEXT_PUBLIC_APP_URL": { "type": "string", "format": "uri" },
    "NEXT_PUBLIC_SUPABASE_URL": { "type": "string", "format": "uri" },
    "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY": {
      "type": "string",
      "minLength": 1
    },
    "NEXT_PUBLIC_SUPABASE_SCHEMA": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "APP_DATABASE_URL": {
      "type": "string",
      "minLength": 1,
      "description": "제한 DB LOGIN role 전용"
    },
    "MIGRATION_DATABASE_URL": {
      "type": "string",
      "description": "CI/deploy 전용, runtime 금지"
    },
    "SUPABASE_SECRET_KEY": {
      "type": "string",
      "description": "optional — privileged adapter 전용. legacy service_role 금지"
    },
    "INTERNAL_CRON_SECRET": { "type": "string", "minLength": 16 },
    "AI_API_KEY": { "type": "string" },
    "MAIL_API_KEY": { "type": "string" }
  }
}
